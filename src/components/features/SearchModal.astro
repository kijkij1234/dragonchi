---
import { Icon } from 'astro-icon/components';
import type { Locale } from '../../config/i18n';
import { useTranslations } from '../../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<div id="search-overlay" class="pointer-events-none fixed inset-0 z-50 bg-background/70 opacity-0 backdrop-blur-sm transition-opacity"></div>
<section
  id="search-modal"
  data-locale={locale}
  class="pointer-events-none fixed top-20 left-1/2 z-50 w-[min(42rem,calc(100vw-2rem))] -translate-x-1/2 scale-95 rounded-lg border border-border bg-popover opacity-0 shadow-2xl transition"
  aria-hidden="true"
  role="dialog"
  aria-modal="true"
  aria-label={t('search.label')}
>
  <div class="flex items-center gap-2 border-b border-border px-3 py-2">
    <Icon name="lucide:search" class="h-4 w-4 text-muted-foreground" />
    <input id="search-input" class="min-w-0 flex-1 bg-transparent py-2 outline-none" placeholder={t('search.placeholder')} />
    <button id="search-close" type="button" class="grid h-8 w-8 place-items-center rounded-md hover:bg-accent" aria-label={t('search.close')}>
      <Icon name="lucide:x" class="h-4 w-4" />
    </button>
  </div>
  <div class="max-h-[60vh] overflow-auto p-2">
    <p id="search-empty" class="px-3 py-10 text-center text-sm text-muted-foreground">{t('search.empty')}</p>
    <p id="search-loading" class="hidden px-3 py-10 text-center text-sm text-muted-foreground">{t('search.loading')}</p>
    <p id="search-no-results" class="hidden px-3 py-10 text-center text-sm text-muted-foreground">{t('search.noResults')}</p>
    <div id="search-results" class="search-bookshelf-grid"></div>
  </div>
</section>
