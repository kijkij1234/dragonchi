---
import { siteConfig } from '../../config/site';

const analytics = siteConfig.analytics;
const enabled = analytics.enabled && analytics.provider === 'umami' && analytics.umami.src && analytics.umami.websiteId;
---

{enabled && (
  <script
    defer
    src={analytics.umami.src}
    data-website-id={analytics.umami.websiteId}
    data-domains={analytics.umami.domains || undefined}
  ></script>
)}
