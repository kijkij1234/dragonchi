---
import { siteConfig } from '../../config/site';

const comments = siteConfig.comments;
const enabled = comments.enabled && comments.provider === 'giscus' && comments.giscus.repo;
---

{enabled && (
  <section class="mt-14 border-t border-border pt-8">
    <script
      src="https://giscus.app/client.js"
      data-repo={comments.giscus.repo}
      data-repo-id={comments.giscus.repoId}
      data-category={comments.giscus.category}
      data-category-id={comments.giscus.categoryId}
      data-mapping={comments.giscus.mapping}
      data-strict={comments.giscus.strict}
      data-reactions-enabled={comments.giscus.reactionsEnabled}
      data-emit-metadata={comments.giscus.emitMetadata}
      data-input-position={comments.giscus.inputPosition}
      data-theme={comments.giscus.theme}
      crossorigin="anonymous"
      async
    ></script>
  </section>
)}
