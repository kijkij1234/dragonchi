---
import { Icon } from 'astro-icon/components';
import type { CollectionEntry } from 'astro:content';
import { localizedEntryPath } from '../../lib/content/entries';
import type { Locale } from '../../config/i18n';
import { useTranslations } from '../../i18n/utils';

interface Props {
  previous?: CollectionEntry<'posts'>;
  next?: CollectionEntry<'posts'>;
  locale: Locale;
}

const { previous, next, locale } = Astro.props;
const t = useTranslations(locale);
---

{(previous || next) && (
  <nav class="mt-12 grid gap-3 border-t border-border pt-8 sm:grid-cols-2" aria-label="Post navigation">
    {previous ? (
      <a href={localizedEntryPath('posts', previous as any)} class="rounded-lg border border-border p-4 hover:bg-accent">
        <span class="flex items-center gap-2 text-sm text-muted-foreground"><Icon name="lucide:arrow-left" class="h-4 w-4" /> {t('postNav.previous')}</span>
        <strong class="mt-2 block">{previous.data.title}</strong>
      </a>
    ) : <span></span>}
    {next && (
      <a href={localizedEntryPath('posts', next as any)} class="rounded-lg border border-border p-4 text-right hover:bg-accent">
        <span class="flex items-center justify-end gap-2 text-sm text-muted-foreground">{t('postNav.next')} <Icon name="lucide:arrow-right" class="h-4 w-4" /></span>
        <strong class="mt-2 block">{next.data.title}</strong>
      </a>
    )}
  </nav>
)}
