---
import { slugTerm } from '../../lib/content/entries';
import type { Locale } from '../../config/i18n';

interface Props {
  locale: Locale;
  tags?: string[];
  categories?: string[];
  series?: string;
}

const { locale, tags = [], categories = [], series } = Astro.props;
const prefix = locale === 'en' ? '' : `/${locale}`;
---

{(tags.length > 0 || categories.length > 0 || series) && (
  <div class="my-8 flex flex-wrap gap-2 text-sm">
    {categories.map((category) => (
      <a href={`${prefix}/categories/${slugTerm(category)}/`} class="rounded-full border border-border px-3 py-1 text-muted-foreground hover:border-primary hover:text-primary">
        {category}
      </a>
    ))}
    {tags.map((tag) => (
      <a href={`${prefix}/tags/${slugTerm(tag)}/`} class="rounded-full bg-muted px-3 py-1 text-muted-foreground hover:text-primary">
        #{tag}
      </a>
    ))}
    {series && (
      <a href={`${prefix}/series/${slugTerm(series)}/`} class="rounded-full bg-primary px-3 py-1 text-primary-foreground">
        {series}
      </a>
    )}
  </div>
)}
