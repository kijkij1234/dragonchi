---
import { Icon } from 'astro-icon/components';
import type { CollectionEntry } from 'astro:content';
import { entryDate, formatDate, localizedEntryPath, type ContentType } from '../../lib/content/entries';
import type { Locale } from '../../config/i18n';

interface Props {
  entry: CollectionEntry<'posts'> | CollectionEntry<'projects'>;
  collection: ContentType;
  locale: Locale;
}

const { entry, collection, locale } = Astro.props;
const href = localizedEntryPath(collection, entry as any);
const date = entryDate(entry as any);
---

<article class="border-b border-border py-6">
  <a href={href} class="group block">
    <div class="flex items-start gap-4">
      {entry.data.cover && (
        <img src={entry.data.cover} alt="" class="hidden h-20 w-28 shrink-0 rounded-lg border border-border object-cover sm:block" loading="lazy" />
      )}
      <div class="min-w-0 flex-1">
        <h2 class="text-xl font-semibold tracking-normal group-hover:text-primary">{entry.data.title}</h2>
        {entry.data.description && <p class="mt-2 text-sm leading-6 text-muted-foreground">{entry.data.description}</p>}
      </div>
      <Icon name="lucide:arrow-right" class="mt-1 h-5 w-5 shrink-0 text-muted-foreground transition-transform group-hover:translate-x-1 group-hover:text-primary" />
    </div>
    <div class="mt-3 flex flex-wrap items-center gap-3 text-xs text-muted-foreground">
      {date.getTime() > 0 && (
        <time datetime={date.toISOString()}>{formatDate(date, locale)}</time>
      )}
      {entry.data.tags?.slice(0, 4).map((tag) => (
        <span class="rounded-full bg-muted px-2 py-0.5">{tag}</span>
      ))}
    </div>
  </a>
</article>
