---
import { Icon } from 'astro-icon/components';
import type { CollectionEntry } from 'astro:content';
import { contentTypes, type EntryCardStyle } from '../../config/content';
import type { Locale } from '../../config/i18n';
import { entryDate, formatDate, localizedEntryPath, type ContentType } from '../../lib/content/entries';

interface Props {
  entry: CollectionEntry<'posts'>;
  collection: keyof typeof contentTypes;
  locale: Locale;
  style?: EntryCardStyle;
  index?: number;
}

const { entry, collection, locale, style, index = 0 } = Astro.props;
const config = contentTypes[collection];
const cardStyle = style ?? config.cardStyle;
const href = localizedEntryPath(collection, entry as any);
const date = entryDate(entry as any);
const tags = entry.data.tags?.slice(0, cardStyle === 'showcase' ? 3 : 4) ?? [];
const hasDate = config.showMeta && date.getTime() > 0;
const isFeatured = 'featured' in entry.data && entry.data.featured;
const links = 'links' in entry.data ? entry.data.links?.slice(0, 2) ?? [] : [];
const bookcover = collection === 'posts' && 'bookcover' in entry.data ? entry.data.bookcover : undefined;
---

{cardStyle === 'showcase' ? (
  <article class="group h-full">
    <a href={href} class="block h-full">
      <div class="relative flex h-full min-h-64 flex-col overflow-hidden rounded-[var(--radius-card)] border border-border bg-card p-6 shadow-[var(--surface-shadow)] transition-all duration-300 ease-out hover:-translate-y-1 hover:border-primary/25 hover:shadow-[var(--surface-shadow-strong)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/25">
        {entry.data.cover ? (
          <>
            <img src={entry.data.cover} alt="" class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/60 to-black/25"></div>
          </>
        ) : (
          <div class="absolute inset-0 bg-primary/5 opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>
        )}

        <div class="relative z-10 flex min-h-52 flex-1 flex-col">
          <div class="flex items-start justify-between gap-3">
            <span class:list={[
              'grid h-8 w-8 place-items-center rounded-full border text-sm',
              entry.data.cover ? 'border-white/15 bg-white/15 text-white backdrop-blur-sm' : 'border-border bg-muted text-primary'
            ]}>
              <Icon name={config.icon} class="h-4 w-4" />
            </span>
            {isFeatured && (
              <span class:list={[
                'grid h-8 w-8 place-items-center rounded-full',
                entry.data.cover ? 'bg-white/15 text-white backdrop-blur-sm' : 'bg-primary/10 text-primary'
              ]}>
                <Icon name="lucide:star" class="h-4 w-4" />
              </span>
            )}
          </div>

          <div class="mt-auto">
            <h2 class:list={[
              'truncate text-xl font-semibold leading-tight transition-colors',
              entry.data.cover ? 'text-white' : 'text-foreground group-hover:text-primary'
            ]}>
              {entry.data.title}
            </h2>
            {entry.data.description && (
              <p class:list={[
                'mt-2 line-clamp-2 text-sm leading-6',
                entry.data.cover ? 'text-white/80' : 'text-muted-foreground'
              ]}>
                {entry.data.description}
              </p>
            )}

            <div class="mt-4 flex flex-wrap items-center gap-2">
              {tags.map((tag) => (
                <span class:list={[
                  'rounded border px-2.5 py-0.5 text-xs font-medium',
                  entry.data.cover ? 'border-white/10 bg-white/15 text-white backdrop-blur-sm' : 'border-border bg-muted text-muted-foreground'
                ]}>{tag}</span>
              ))}
              {links.length > 0 && (
                <span class:list={[
                  'ml-auto inline-flex items-center gap-1 text-xs font-medium',
                  entry.data.cover ? 'text-white/80' : 'text-muted-foreground'
                ]}>
                  {links.length}
                  <Icon name="lucide:link" class="h-3.5 w-3.5" />
                </span>
              )}
            </div>
          </div>
        </div>
      </div>
    </a>
  </article>
) : cardStyle === 'compact' ? (
  <article class="border-b border-border py-4">
    <a href={href} class="group flex items-center justify-between gap-4">
      <div class="min-w-0">
        <h2 class="truncate text-base font-medium group-hover:text-primary">{entry.data.title}</h2>
        {hasDate && <time datetime={date.toISOString()} class="mt-1 block text-xs text-muted-foreground">{formatDate(date, locale)}</time>}
      </div>
      <Icon name="lucide:arrow-right" class="h-4 w-4 shrink-0 text-muted-foreground transition-transform group-hover:translate-x-1 group-hover:text-primary" />
    </a>
  </article>
) : (
  <article class="bookshelf-item group" style={`--motion-delay: ${Math.min(index, 10) * 45}ms`}>
    <a href={href} class="bookshelf-link focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/25">
      <div class="bookshelf-cover" aria-hidden={!bookcover}>
        {bookcover ? (
          <img src={bookcover} alt="" class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105" loading="lazy" />
        ) : (
          <div class="flex h-full w-full items-center justify-center bg-muted text-primary">
            <Icon name={config.icon} class="h-10 w-10" />
          </div>
        )}
      </div>

      <div class="bookshelf-meta">
        {hasDate && <time datetime={date.toISOString()} class="bookshelf-date">{formatDate(date, locale)}</time>}
        <h2 class="bookshelf-title transition-colors group-hover:text-primary">{entry.data.title}</h2>
      </div>
    </a>
  </article>
)}
