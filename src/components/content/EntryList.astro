---
import type { CollectionEntry } from 'astro:content';
import { contentTypes, type ContentTypeId } from '../../config/content';
import type { Locale } from '../../config/i18n';
import EntryCard from './EntryCard.astro';

interface Props {
  entries: Array<CollectionEntry<'posts'> | CollectionEntry<'projects'>>;
  collection: ContentTypeId;
  locale: Locale;
}

const { entries, collection, locale } = Astro.props;
const config = contentTypes[collection];
const gridClasses = {
  1: 'grid gap-4',
  2: 'grid gap-4 sm:grid-cols-2',
  3: 'grid gap-4 sm:grid-cols-2 lg:grid-cols-3'
};
const listClass = config.listLayout === 'grid'
  ? gridClasses[config.gridColumns]
  : 'space-y-4';
---

<div class={listClass}>
  {entries.map((entry) => <EntryCard entry={entry} collection={collection} locale={locale} />)}
</div>
