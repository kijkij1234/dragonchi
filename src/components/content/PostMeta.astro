---
import { Icon } from 'astro-icon/components';
import type { Locale } from '../../config/i18n';
import { formatDate, slugTerm } from '../../lib/content/entries';
import { useTranslations } from '../../i18n/utils';

interface Props {
  title: string;
  description?: string;
  date?: Date;
  locale: Locale;
  minutesRead?: number;
  wordCount?: number;
  tags?: string[];
  categories?: string[];
  series?: string;
}

const {
  title,
  description,
  date,
  locale,
  minutesRead,
  wordCount,
  tags = [],
  categories = [],
  series
} = Astro.props;

const t = useTranslations(locale);
const prefix = locale === 'en' ? '' : `/${locale}`;
const hasTaxonomy = categories.length > 0 || tags.length > 0 || Boolean(series);
---

<header class="mb-10">
  <h1 class="text-3xl font-bold leading-tight tracking-tight sm:text-4xl">{title}</h1>
  {description && <p class="mt-4 text-lg leading-relaxed text-muted-foreground">{description}</p>}

  <div class="surface-panel mt-6 p-5 text-sm">
    <div class="flex flex-wrap items-center gap-x-5 gap-y-2 text-muted-foreground">
      {date && date.getTime() > 0 && (
        <span class="inline-flex items-center gap-1.5">
          <Icon name="lucide:calendar" class="h-4 w-4" />
          <time datetime={date.toISOString()}>{formatDate(date, locale)}</time>
        </span>
      )}
      {minutesRead && (
        <span class="inline-flex items-center gap-1.5">
          <Icon name="lucide:clock" class="h-4 w-4" />
          <span>{minutesRead} {t('post.minRead')}</span>
        </span>
      )}
      {wordCount && wordCount > 0 && (
        <span class="inline-flex items-center gap-1.5">
          <Icon name="lucide:type" class="h-4 w-4" />
          <span>{wordCount.toLocaleString(locale === 'zh-cn' ? 'zh-CN' : 'en')} {t('post.words')}</span>
        </span>
      )}
    </div>

    {hasTaxonomy && (
      <div class="mt-4 flex flex-wrap items-center gap-2 border-t border-border pt-4 text-sm">
        {categories.map((category) => (
          <a
            href={`${prefix}/categories/${slugTerm(category)}/`}
            class="rounded-full border border-border px-3 py-1 text-muted-foreground transition-colors hover:border-primary hover:text-primary"
          >
            {category}
          </a>
        ))}
        {tags.map((tag) => (
          <a
            href={`${prefix}/tags/${slugTerm(tag)}/`}
            class="rounded-full bg-muted px-3 py-1 text-muted-foreground transition-colors hover:text-primary"
          >
            #{tag}
          </a>
        ))}
        {series && (
          <a
            href={`${prefix}/series/${slugTerm(series)}/`}
            class="rounded-full bg-primary px-3 py-1 text-primary-foreground"
          >
            {series}
          </a>
        )}
      </div>
    )}
  </div>
</header>
