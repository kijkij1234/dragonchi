---
import { Icon } from 'astro-icon/components';
import type { CollectionEntry } from 'astro:content';
import { getLocalePath, type Locale } from '../../config/i18n';
import { formatDate, slugTerm } from '../../lib/content/entries';
import SeriesNav from './SeriesNav.astro';

interface SeriesGroup {
  slug: string;
  title: string;
  href: string;
  posts: CollectionEntry<'posts'>[];
}

interface Props {
  title: string;
  description?: string;
  date?: Date;
  locale: Locale;
  tags?: string[];
  seriesGroups?: SeriesGroup[];
  current?: CollectionEntry<'posts'>;
}

const {
  title,
  description,
  date,
  locale,
  tags = [],
  seriesGroups = [],
  current
} = Astro.props;

const hasTaxonomy = tags.length > 0;
const hasSeries = seriesGroups.length > 0 && current;
---

<header class="mb-10">
  <h1 class="text-3xl font-bold leading-tight tracking-tight sm:text-4xl">{title}</h1>
  {description && <p class="mt-4 text-lg leading-relaxed text-muted-foreground">{description}</p>}

  <div class:list={['surface-panel mt-6 text-sm', hasSeries && 'sm:flex sm:items-stretch']}>
    <div class:list={['p-5', hasSeries && 'sm:w-3/5 sm:border-r sm:border-border']}>
      <div class="flex flex-wrap items-center gap-x-5 gap-y-2 text-muted-foreground">
        {date && date.getTime() > 0 && (
          <span class="inline-flex items-center gap-1.5">
            <Icon name="lucide:calendar" class="h-4 w-4" />
            <time datetime={date.toISOString()}>{formatDate(date, locale)}</time>
          </span>
        )}
      </div>

      {hasTaxonomy && (
        <div class="mt-4 flex flex-wrap items-center gap-2 border-t border-border pt-4 text-sm">
          {tags.map((tag: string) => (
            <a
              href={getLocalePath(locale, `/tags/${slugTerm(tag)}/`)}
              class="rounded-full bg-muted px-3 py-1 text-muted-foreground transition-colors hover:text-primary"
            >
              #{tag}
            </a>
          ))}
        </div>
      )}
    </div>

    {hasSeries && (
      <div class="border-t border-border p-4 sm:w-2/5 sm:border-t-0">
        <SeriesNav groups={seriesGroups} current={current!} locale={locale} />
      </div>
    )}
  </div>
</header>
