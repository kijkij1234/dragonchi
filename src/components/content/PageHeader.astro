---
import type { Locale } from '../../config/i18n';
import { formatDate } from '../../lib/content/entries';

interface Props {
  title: string;
  description?: string;
  date?: Date;
  locale: Locale;
}

const { title, description, date, locale } = Astro.props;
---

<header class="mb-10">
  {date && <time class="text-sm text-muted-foreground" datetime={date.toISOString()}>{formatDate(date, locale)}</time>}
  <h1 class="mt-2 text-3xl font-bold tracking-normal sm:text-4xl">{title}</h1>
  {description && <p class="mt-4 max-w-2xl text-muted-foreground">{description}</p>}
</header>
