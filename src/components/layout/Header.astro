---
import { Icon } from 'astro-icon/components';
import { getLocalePath, locales, localeMeta, switchLocalePath, type Locale } from '../../config/i18n';
import { getNavigation } from '../../config/navigation';
import { siteConfig } from '../../config/site';
import { themes } from '../../config/theme';
import { useTranslations } from '../../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const navigation = getNavigation(locale);
const currentPath = Astro.url.pathname;
const t = useTranslations(locale);

function isActive(href: string) {
  if (href === '/') return currentPath === href;
  return currentPath === href || currentPath.startsWith(href);
}
---

<header class="sticky top-3 z-30 mb-10">
  <div class="nav-shell flex min-h-14 items-center justify-between gap-3 border px-3 shadow-[var(--surface-shadow)]">
    <a href={getLocalePath(locale, '/')} class="flex min-w-0 items-center gap-2 font-semibold">
      <span class="grid h-8 w-8 shrink-0 place-items-center rounded-md bg-primary text-primary-foreground">
        {siteConfig.name.slice(0, 1)}
      </span>
      <span class="truncate">{siteConfig.name}</span>
    </a>

    <nav class="hidden items-center gap-1 md:flex" aria-label="Primary">
      {navigation.map((item) => (
        <a
          class:list={[
            'nav-item inline-flex items-center gap-1.5 rounded-[var(--radius-control)] px-3 py-2 text-sm transition-all duration-300',
            isActive(item.href)
              ? 'bg-accent text-accent-foreground shadow-sm ring-1 ring-primary/35'
              : 'text-muted-foreground hover:bg-accent hover:text-accent-foreground hover:shadow-sm'
          ]}
          href={item.href}
        >
          <Icon name={item.icon} class="h-4 w-4" />
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-1">
      <button type="button" data-mobile-menu class="grid h-9 w-9 place-items-center rounded-[var(--radius-control)] hover:bg-accent md:hidden" aria-label={t('nav.menu')}>
        <Icon name="lucide:menu" class="h-4 w-4" />
      </button>

      <button type="button" data-search-open class="grid h-9 w-9 place-items-center rounded-[var(--radius-control)] hover:bg-accent" aria-label={t('nav.search')}>
        <Icon name="lucide:search" class="h-4 w-4" />
      </button>

      <div class="relative">
        <button type="button" data-theme-menu class="grid h-9 w-9 place-items-center rounded-[var(--radius-control)] hover:bg-accent" aria-label={t('nav.theme')}>
          <Icon name="lucide:palette" class="h-4 w-4" />
        </button>
        <div data-theme-panel class="absolute right-0 mt-2 hidden max-h-80 w-48 overflow-auto rounded-[var(--radius-panel)] border border-border bg-popover p-1 text-sm shadow-xl">
          {themes.map((theme) => (
            <button type="button" data-theme-value={theme.id} class="flex w-full items-center rounded-[var(--radius-control)] px-2 py-1.5 text-left hover:bg-accent">
              <span>{theme.name}</span>
            </button>
          ))}
        </div>
      </div>

      <button type="button" data-color-mode class="grid h-9 w-9 place-items-center rounded-[var(--radius-control)] hover:bg-accent" aria-label={t('nav.colorMode')}>
        <Icon name="lucide:sun-moon" class="h-4 w-4" />
      </button>

      <div class="relative">
        <button type="button" data-lang-menu class="grid h-9 w-9 place-items-center rounded-[var(--radius-control)] hover:bg-accent" aria-label={t('nav.language')}>
          <Icon name="lucide:languages" class="h-4 w-4" />
        </button>
        <div data-lang-panel class="absolute right-0 mt-2 hidden w-36 rounded-[var(--radius-panel)] border border-border bg-popover p-1 text-sm shadow-xl">
          {locales.map((item) => (
            <a href={switchLocalePath(item, currentPath)} class="block rounded px-2 py-1.5 hover:bg-accent" aria-current={item === locale ? 'page' : undefined}>
              {localeMeta[item].label}
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
  <nav data-mobile-panel class="mt-2 hidden rounded-[var(--radius-card)] border border-border bg-popover p-2 shadow-xl md:hidden" aria-label="Mobile primary">
    {navigation.map((item) => (
      <a class:list={['flex items-center gap-2 rounded-[var(--radius-control)] px-3 py-2 text-sm', isActive(item.href) ? 'bg-accent text-accent-foreground ring-1 ring-primary/35' : 'text-muted-foreground hover:bg-accent hover:text-accent-foreground']} href={item.href}>
        <Icon name={item.icon} class="h-4 w-4" />
        {item.label}
      </a>
    ))}
  </nav>
</header>
