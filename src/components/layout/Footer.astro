---
import { Icon } from 'astro-icon/components';
import type { Locale } from '../../config/i18n';
import { siteConfig } from '../../config/site';

interface Props {
  locale: Locale;
}

const year = new Date().getFullYear();
---

<footer class="mt-16 border-t border-border py-8 text-sm text-muted-foreground">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <p>© {year} {siteConfig.author.name}</p>
    <div class="flex items-center gap-2">
      {siteConfig.author.social.map((item) => (
        <a class="grid h-9 w-9 place-items-center rounded-md hover:bg-accent hover:text-accent-foreground" href={item.url} aria-label={item.name}>
          <Icon name={item.icon} class="h-4 w-4" />
        </a>
      ))}
    </div>
  </div>
</footer>
