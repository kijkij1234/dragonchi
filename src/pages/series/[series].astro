---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import EntryList from '../../components/content/EntryList.astro';
import PageHeader from '../../components/content/PageHeader.astro';
import { contentTypes } from '../../config/content';
import { getLocalizedEntries, seriesPosts } from '../../lib/content/entries';

export async function getStaticPaths() {
  const taxonomy = contentTypes.posts.taxonomies!.series;
  const posts = await getLocalizedEntries('posts', 'en');
  return Object.keys(taxonomy.terms ?? {}).map((slug) => ({
    params: { series: slug },
    props: {
      title: taxonomy.terms![slug].label.en,
      description: taxonomy.terms![slug].description?.en,
      posts: seriesPosts(posts, slug)
    }
  }));
}

const { title, description, posts } = Astro.props;
---

<BaseLayout title={title} description={description} locale="en">
  <PageHeader title={title} description={description} locale="en" />
  <EntryList entries={posts} collection="posts" locale="en" />
</BaseLayout>
