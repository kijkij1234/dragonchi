---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import PageHeader from '../../components/content/PageHeader.astro';
import SeriesList from '../../components/content/SeriesList.astro';
import { defaultLocale } from '../../config/i18n';
import { getLocalizedSeries } from '../../lib/content/series';
import { useTranslations } from '../../i18n/utils';

const locale = defaultLocale;
const series = await getLocalizedSeries(locale);
const t = useTranslations(locale);
---

<BaseLayout title={t('series.title')} description={t('series.description')} locale={locale}>
  <PageHeader title={t('series.title')} description={t('series.description')} locale={locale} />
  <SeriesList series={series} locale={locale} />
</BaseLayout>
