---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import PageHeader from '../../components/content/PageHeader.astro';
import SeriesCard from '../../components/content/SeriesCard.astro';
import { contentTypes } from '../../config/content';
import { getLocalePath } from '../../config/i18n';
import { getLocalizedEntries, seriesPosts, slugTerm } from '../../lib/content/entries';
import { useTranslations } from '../../i18n/utils';

const locale = 'en';
const taxonomy = contentTypes.posts.taxonomies!.series;
const posts = await getLocalizedEntries('posts', locale);
const t = useTranslations(locale);

const seriesList = Object.entries(taxonomy.terms ?? {}).map(([slug, meta]) => {
  const seriesPostList = seriesPosts(posts, slug);
  return {
    slug,
    title: meta.label[locale],
    description: meta.description?.[locale],
    cover: meta.cover,
    count: seriesPostList.length,
    href: getLocalePath(locale, `/series/${slug}/`),
  };
});
---

<BaseLayout title={t('series.title')} description={t('series.description')} locale={locale}>
  <PageHeader title={t('series.title')} description={t('series.description')} locale={locale} />
  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {seriesList.map((item) => (
      <SeriesCard
        title={item.title}
        description={item.description}
        cover={item.cover}
        count={item.count}
        href={item.href}
        countLabel={t('taxonomy.count')}
      />
    ))}
  </div>
</BaseLayout>
