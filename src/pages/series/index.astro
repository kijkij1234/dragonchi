---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import PageHeader from '../../components/content/PageHeader.astro';
import TermCloud from '../../components/content/TermCloud.astro';
import { getLocalizedEntries, uniqueSeries } from '../../lib/content/entries';
import { useTranslations } from '../../i18n/utils';

const locale = 'en';
const posts = await getLocalizedEntries('posts', locale);
const terms = uniqueSeries(posts);
const t = useTranslations(locale);
---

<BaseLayout title={t('taxonomy.seriesTitle')} description={t('taxonomy.seriesDescription')} locale={locale}>
  <PageHeader title={t('taxonomy.seriesTitle')} description={t('taxonomy.seriesDescription')} locale={locale} />
  <TermCloud terms={terms} basePath="/series/" />
</BaseLayout>
