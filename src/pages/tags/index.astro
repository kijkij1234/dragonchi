---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import PageHeader from '../../components/content/PageHeader.astro';
import TermCloud from '../../components/content/TermCloud.astro';
import { getLocalizedEntries, uniqueTerms } from '../../lib/content/entries';
import { useTranslations } from '../../i18n/utils';

const locale = 'en';
const posts = await getLocalizedEntries('posts', locale);
const terms = uniqueTerms(posts, 'tags');
const t = useTranslations(locale);
---

<BaseLayout title={t('taxonomy.tagsTitle')} description={t('taxonomy.tagsDescription')} locale={locale}>
  <PageHeader title={t('taxonomy.tagsTitle')} description={t('taxonomy.tagsDescription')} locale={locale} />
  <TermCloud terms={terms} basePath="/tags/" />
</BaseLayout>
