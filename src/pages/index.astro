---
import BaseLayout from '../components/layout/BaseLayout.astro';
import HomePage from '../components/home/HomePage.astro';
import { siteConfig } from '../config/site';
import { getLocalizedEntries } from '../lib/content/entries';

const locale = 'en';
const posts = (await getLocalizedEntries('posts', locale)).slice(0, 5);
const projects = (await getLocalizedEntries('projects', locale)).filter((entry) => entry.data.featured).slice(0, 3);
---

<BaseLayout title={siteConfig.name} description={siteConfig.description} locale={locale}>
  <HomePage locale={locale} posts={posts} projects={projects} />
</BaseLayout>
