---
import { render } from 'astro:content';
import BaseLayout from '../../components/layout/BaseLayout.astro';
import Breadcrumbs from '../../components/content/Breadcrumbs.astro';
import PostMeta from '../../components/content/PostMeta.astro';
import PostNavigation from '../../components/content/PostNavigation.astro';
import { contentTypes } from '../../config/content';
import { defaultLocale, getLocalePath } from '../../config/i18n';
import { siteConfig } from '../../config/site';
import { adjacentEntries, getLocalizedEntries, entrySlug } from '../../lib/content/entries';
import { getSeriesContext, localizedSeriesPath } from '../../lib/content/series';

export async function getStaticPaths() {
  const posts = await getLocalizedEntries('posts', defaultLocale);
  return posts.map((entry) => ({ params: { slug: entrySlug(entry as any) }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const posts = await getLocalizedEntries('posts', defaultLocale);
const seriesContext = await getSeriesContext(entry);
const adjacent = seriesContext || adjacentEntries(posts, entry);
---

<BaseLayout title={entry.data.title} description={entry.data.description} locale={defaultLocale} headings={headings} toc={entry.data.toc ?? 'center'} comments={entry.data.comments}>
  <Breadcrumbs
    locale={defaultLocale}
    items={[
      { label: siteConfig.shortName, href: getLocalePath(defaultLocale, '/'), icon: 'lucide:home' },
      { label: contentTypes.posts.label[defaultLocale], href: getLocalePath(defaultLocale, contentTypes.posts.path), icon: contentTypes.posts.icon },
      { label: entry.data.title, icon: 'lucide:file-text' }
    ]}
  />
  {entry.data.cover && (
    <div class="mb-8 overflow-hidden rounded-[var(--radius-card)]">
      <img src={entry.data.cover} alt={entry.data.title} class="aspect-video max-h-[60vh] w-full object-cover" loading="eager" />
    </div>
  )}
  <PostMeta
    title={entry.data.title}
    description={entry.data.description}
    date={entry.data.pubDate}
    locale={defaultLocale}
    categories={entry.data.categories}
    tags={entry.data.tags}
    series={seriesContext ? {
      title: seriesContext.series.entry.data.title,
      href: localizedSeriesPath(seriesContext.series.entry),
      position: seriesContext.position,
      total: seriesContext.series.chapters.length
    } : undefined}
  />
  <article class="prose mb-12 max-w-none">
    <Content />
  </article>
  <PostNavigation previous={adjacent.previous} next={adjacent.next} locale={defaultLocale} kind={seriesContext ? 'series' : 'post'} />
</BaseLayout>
