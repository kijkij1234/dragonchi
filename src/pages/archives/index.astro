---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import PageHeader from '../../components/content/PageHeader.astro';
import ArchiveTimeline from '../../components/content/ArchiveTimeline.astro';
import { getLocalizedEntries } from '../../lib/content/entries';
import { useTranslations } from '../../i18n/utils';

const locale = 'en';
const posts = await getLocalizedEntries('posts', locale);
const t = useTranslations(locale);
---

<BaseLayout title={t('archive.title')} description={t('archive.description')} locale={locale}>
  <PageHeader title={t('archive.title')} description={t('archive.description')} locale={locale} />
  <ArchiveTimeline posts={posts} locale={locale} />
</BaseLayout>
