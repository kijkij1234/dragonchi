---
import BaseLayout from '../../../components/layout/BaseLayout.astro';
import EntryList from '../../../components/content/EntryList.astro';
import PageHeader from '../../../components/content/PageHeader.astro';
import { defaultLocale, locales, type Locale } from '../../../config/i18n';
import { getLocalizedEntries } from '../../../lib/content/entries';
import { useTranslations } from '../../../i18n/utils';

export function getStaticPaths() {
  return locales.filter((locale) => locale !== defaultLocale).map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale as Locale;
const posts = await getLocalizedEntries('posts', locale);
const t = useTranslations(locale);
---

<BaseLayout title={t('posts.title')} description={t('posts.description')} locale={locale}>
  <PageHeader title={t('posts.title')} description={t('posts.description')} locale={locale} />
  <EntryList entries={posts} collection="posts" locale={locale} />
</BaseLayout>
