---
import { render } from 'astro:content';
import BaseLayout from '../../../components/layout/BaseLayout.astro';
import PostMeta from '../../../components/content/PostMeta.astro';
import PostLicense from '../../../components/content/PostLicense.astro';
import PostNavigation from '../../../components/content/PostNavigation.astro';
import RelatedPosts from '../../../components/content/RelatedPosts.astro';
import { locales, type Locale } from '../../../config/i18n';
import { siteConfig } from '../../../config/site';
import { adjacentEntries, getLocalizedEntries, entrySlug, relatedPosts } from '../../../lib/content/entries';

export async function getStaticPaths() {
  const paths = [];
  for (const locale of locales.filter((item) => item !== 'en')) {
    const posts = await getLocalizedEntries('posts', locale);
    paths.push(...posts.map((entry) => ({ params: { locale, slug: entrySlug(entry as any) }, props: { entry, locale } })));
  }
  return paths;
}

const { entry, locale } = Astro.props as any as { entry: any; locale: Locale };
const { Content, headings, remarkPluginFrontmatter } = await render(entry);
const posts = await getLocalizedEntries('posts', locale);
const adjacent = adjacentEntries(posts, entry);
const related = relatedPosts(posts, entry, siteConfig.post.relatedCount);
---

<BaseLayout title={entry.data.title} description={entry.data.description} locale={locale} headings={headings} toc={entry.data.toc ?? 'center'} comments={entry.data.comments}>
  {entry.data.cover && (
    <div class="mb-8 overflow-hidden rounded-[var(--radius-card)]">
      <img src={entry.data.cover} alt={entry.data.title} class="aspect-video max-h-[60vh] w-full object-cover" loading="eager" />
    </div>
  )}
  <PostMeta
    title={entry.data.title}
    description={entry.data.description}
    date={entry.data.pubDate}
    locale={locale}
    minutesRead={remarkPluginFrontmatter.minutesRead}
    wordCount={remarkPluginFrontmatter.wordCount}
    tags={entry.data.tags}
    categories={entry.data.categories}
    series={entry.data.series}
  />
  <article class="prose mb-12 max-w-none">
    <Content />
  </article>
  <PostLicense locale={locale} />
  <PostNavigation previous={adjacent.previous} next={adjacent.next} locale={locale} />
  <RelatedPosts posts={related} locale={locale} />
</BaseLayout>
