---
import BaseLayout from '../../../components/layout/BaseLayout.astro';
import PageHeader from '../../../components/content/PageHeader.astro';
import SeriesCard from '../../../components/content/SeriesCard.astro';
import { locales, type Locale } from '../../../config/i18n';
import { getLocalizedEntries, seriesPosts, entrySlug } from '../../../lib/content/entries';
import { useTranslations } from '../../../i18n/utils';

export function getStaticPaths() {
  return locales.filter((locale) => locale !== 'en').map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale as Locale;
const series = await getLocalizedEntries('series', locale);
const posts = await getLocalizedEntries('posts', locale);
const t = useTranslations(locale);
---

<BaseLayout title={t('series.title')} description={t('series.description')} locale={locale}>
  <PageHeader title={t('series.title')} description={t('series.description')} locale={locale} />
  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {series.map((entry) => (
      <SeriesCard entry={entry} count={seriesPosts(posts, entrySlug(entry as any)).length} locale={locale} />
    ))}
  </div>
</BaseLayout>
