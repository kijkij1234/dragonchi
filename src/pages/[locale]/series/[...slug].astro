---
import { render } from 'astro:content';
import BaseLayout from '../../../components/layout/BaseLayout.astro';
import Breadcrumbs from '../../../components/content/Breadcrumbs.astro';
import PageHeader from '../../../components/content/PageHeader.astro';
import SeriesChapterList from '../../../components/content/SeriesChapterList.astro';
import { defaultLocale, getLocalePath, locales, type Locale } from '../../../config/i18n';
import { siteConfig } from '../../../config/site';
import { getLocalizedSeries, type ResolvedSeries } from '../../../lib/content/series';
import { useTranslations } from '../../../i18n/utils';

export async function getStaticPaths() {
  const paths = [];
  for (const locale of locales.filter((item) => item !== defaultLocale)) {
    const series = await getLocalizedSeries(locale);
    paths.push(...series.map((item) => ({ params: { locale, slug: item.slug }, props: { item, locale } })));
  }
  return paths;
}

const { item, locale } = Astro.props as { item: ResolvedSeries; locale: Locale };
const { Content } = await render(item.entry);
const t = useTranslations(locale);

function assetPath(path: string) {
  if (/^(https?:)?\/\//.test(path) || path.startsWith('data:')) return path;
  const base = import.meta.env.BASE_URL || '/';
  return `${base.replace(/\/?$/, '/')}${path.replace(/^\//, '')}`;
}
---

<BaseLayout title={item.entry.data.title} description={item.entry.data.description} locale={locale}>
  <Breadcrumbs
    locale={locale}
    items={[
      { label: siteConfig.shortName, href: getLocalePath(locale, '/'), icon: 'lucide:home' },
      { label: t('series.title'), href: getLocalePath(locale, '/series/'), icon: 'lucide:folder' },
      { label: item.entry.data.title, icon: 'lucide:book-open' }
    ]}
  />
  <div class="mb-10 flex items-start gap-4">
    {item.entry.data.seriesicon && (
      <img src={assetPath(item.entry.data.seriesicon)} alt="" class="mt-1 h-12 w-12 shrink-0 rounded-[var(--radius-panel)] border border-border object-cover" loading="eager" />
    )}
    <PageHeader title={item.entry.data.title} description={item.entry.data.description} locale={locale} class="mb-0" />
  </div>
  <article class="prose max-w-none">
    <Content />
  </article>
  <SeriesChapterList chapters={item.chapters} locale={locale} />
</BaseLayout>
