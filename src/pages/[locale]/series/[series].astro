---
import BaseLayout from '../../../components/layout/BaseLayout.astro';
import EntryCard from '../../../components/content/EntryCard.astro';
import PageHeader from '../../../components/content/PageHeader.astro';
import { locales, type Locale } from '../../../config/i18n';
import { getLocalizedEntries, slugTerm } from '../../../lib/content/entries';
import { useTranslations } from '../../../i18n/utils';

export async function getStaticPaths() {
  const paths = [];
  for (const locale of locales.filter((item) => item !== 'en')) {
    const posts = await getLocalizedEntries('posts', locale);
    const series = [...new Set(posts.map((entry) => entry.data.series).filter(Boolean))] as string[];
    paths.push(...series.map((name) => ({ params: { locale, series: slugTerm(name) }, props: { locale, name, posts: posts.filter((entry) => entry.data.series && slugTerm(entry.data.series) === slugTerm(name)) } })));
  }
  return paths;
}

const { locale, name, posts } = Astro.props as any as { locale: Locale; name: string; posts: any[] };
const t = useTranslations(locale);
---

<BaseLayout title={`${t('taxonomy.seriesPrefix')}：${name}`} locale={locale}>
  <PageHeader title={`${t('taxonomy.seriesPrefix')}：${name}`} description={`${posts.length} ${t('taxonomy.count')}`} locale={locale} />
  {posts.map((entry) => <EntryCard entry={entry} collection="posts" locale={locale} />)}
</BaseLayout>
