---
import BaseLayout from '../../../components/layout/BaseLayout.astro';
import PageHeader from '../../../components/content/PageHeader.astro';
import ArchiveTimeline from '../../../components/content/ArchiveTimeline.astro';
import ArchiveFilters from '../../../components/content/ArchiveFilters.astro';
import { defaultLocale, locales, type Locale } from '../../../config/i18n';
import { collectArchiveTerms, getLocalizedEntries } from '../../../lib/content/entries';
import { useTranslations } from '../../../i18n/utils';

export function getStaticPaths() {
  return locales.filter((locale) => locale !== defaultLocale).map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale as Locale;
const posts = await getLocalizedEntries('posts', locale);
const categories = collectArchiveTerms(posts, 'categories', locale);
const tags = collectArchiveTerms(posts, 'tags', locale);
const t = useTranslations(locale);
---

<BaseLayout title={t('archive.title')} description={t('archive.description')} locale={locale}>
  <PageHeader title={t('archive.title')} description={t('archive.description')} locale={locale} />
  <ArchiveFilters categories={categories} tags={tags} total={posts.length} locale={locale} />
  <ArchiveTimeline posts={posts} locale={locale} />
</BaseLayout>
