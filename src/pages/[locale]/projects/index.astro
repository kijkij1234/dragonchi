---
import BaseLayout from '../../../components/layout/BaseLayout.astro';
import EntryCard from '../../../components/content/EntryCard.astro';
import PageHeader from '../../../components/content/PageHeader.astro';
import { locales, type Locale } from '../../../config/i18n';
import { getLocalizedEntries } from '../../../lib/content/entries';
import { useTranslations } from '../../../i18n/utils';

export function getStaticPaths() {
  return locales.filter((locale) => locale !== 'en').map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale as Locale;
const projects = await getLocalizedEntries('projects', locale);
const t = useTranslations(locale);
---

<BaseLayout title={t('projects.title')} description={t('projects.description')} locale={locale}>
  <PageHeader title={t('projects.title')} description={t('projects.description')} locale={locale} />
  {projects.map((entry) => <EntryCard entry={entry} collection="projects" locale={locale} />)}
</BaseLayout>
