---
import { render } from 'astro:content';
import BaseLayout from '../../../components/layout/BaseLayout.astro';
import PageHeader from '../../../components/content/PageHeader.astro';
import ProjectLinks from '../../../components/content/ProjectLinks.astro';
import { locales, type Locale } from '../../../config/i18n';
import { getLocalizedEntries, entrySlug } from '../../../lib/content/entries';

export async function getStaticPaths() {
  const paths = [];
  for (const locale of locales.filter((item) => item !== 'en')) {
    const projects = await getLocalizedEntries('projects', locale);
    paths.push(...projects.map((entry) => ({ params: { locale, slug: entrySlug(entry as any) }, props: { entry, locale } })));
  }
  return paths;
}

const { entry, locale } = Astro.props as any as { entry: any; locale: Locale };
const { Content, headings } = await render(entry);
---

<BaseLayout title={entry.data.title} description={entry.data.description} locale={locale} headings={headings} toc={entry.data.toc ?? 'center'}>
  <PageHeader title={entry.data.title} description={entry.data.description} date={entry.data.pubDate} locale={locale} />
  <ProjectLinks links={entry.data.links} locale={locale} />
  <article class="prose mb-12 max-w-none">
    <Content />
  </article>
</BaseLayout>
