---
import { render } from 'astro:content';
import BaseLayout from '../../components/layout/BaseLayout.astro';
import PageHeader from '../../components/content/PageHeader.astro';
import { locales, type Locale } from '../../config/i18n';
import { getLocalizedEntries, entrySlug } from '../../lib/content/entries';

export async function getStaticPaths() {
  const paths = [];
  for (const locale of locales.filter((item) => item !== 'en')) {
    const pages = await getLocalizedEntries('pages', locale);
    paths.push(...pages.map((entry) => ({ params: { locale, slug: entrySlug(entry as any) }, props: { entry, locale } })));
  }
  return paths;
}

const { entry, locale } = Astro.props as any as { entry: any; locale: Locale };
const { Content, headings } = await render(entry);
const isTimeline = entry.data.layout === 'timeline';
---

<BaseLayout title={entry.data.title} description={entry.data.description} locale={locale} headings={headings} toc={entry.data.toc ?? (headings.length > 0 ? 'side' : false)} comments={entry.data.comments}>
  <PageHeader title={entry.data.title} description={entry.data.description} date={entry.data.pubDate} locale={locale} />
  <article class:list={['prose mb-12 max-w-none', { 'timeline-prose': isTimeline }]}>
    <Content />
  </article>
</BaseLayout>
