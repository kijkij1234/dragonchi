---
import BaseLayout from '../../../components/layout/BaseLayout.astro';
import EntryList from '../../../components/content/EntryList.astro';
import PageHeader from '../../../components/content/PageHeader.astro';
import { locales, type Locale } from '../../../config/i18n';
import { getLocalizedEntries, slugTerm, uniqueTerms } from '../../../lib/content/entries';
import { useTranslations } from '../../../i18n/utils';

export async function getStaticPaths() {
  const paths = [];
  for (const locale of locales.filter((item) => item !== 'en')) {
    const posts = await getLocalizedEntries('posts', locale);
    paths.push(...uniqueTerms(posts, 'tags').map((term) => ({ params: { locale, tag: term.slug }, props: { locale, term, posts: posts.filter((entry) => entry.data.tags?.some((tag) => slugTerm(tag) === term.slug)) } })));
  }
  return paths;
}

const { locale, term, posts } = Astro.props as any as { locale: Locale; term: any; posts: any[] };
const t = useTranslations(locale);
---

<BaseLayout title={`${t('taxonomy.tagPrefix')}：${term.name}`} locale={locale}>
  <PageHeader title={`${t('taxonomy.tagPrefix')}：${term.name}`} description={`${term.count} ${t('taxonomy.count')}`} locale={locale} />
  <EntryList entries={posts} collection="posts" locale={locale} />
</BaseLayout>
